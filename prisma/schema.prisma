generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

// Default: local SQLite for dev. Switch to Postgres URL for production (Supabase/Neon/Railway).
// Just change provider to "postgresql" and set DATABASE_URL in your .env
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id            Int       @id @default(autoincrement())
  name          String
  website       String    @default("")
  pipeline      String    // pr-marketing | fund-formation | legal-consulting | coaching-ops | media | ai-consulting | legal-freelance | pr-freelance
  industry      String    @default("")
  size          String    @default("")
  revenue       String    @default("")
  location      String    @default("")
  fundingStage  String    @default("")
  techStack     String    @default("[]") // JSON array stored as string
  stage         String    @default("Targeted") // funnel stage
  fitScore      Int       @default(0)
  intentScore   Int       @default(0)
  fitDetails    String    @default("{}") // JSON object
  intentDetails String    @default("{}") // JSON object
  starred       Boolean   @default(false)
  archived      Boolean   @default(false)
  notes         String    @default("")
  personalNotes String    @default("") // relationship notes: "jets fan, lives in jersey"
  // Freelance opportunity fields (populated by enhanced scrapers)
  vertical        String    @default("")   // legal | pr | ""
  subvertical     String    @default("")   // fund | corporate | GC | contracts | media-relations | comms | investor-pr
  engagementModel String    @default("")   // freelance | contract | consultant | fractional | interim | part-time
  buyerType       String    @default("")   // law-firm | fund | operating-company | agency | staffing | ALSP
  compensationText String   @default("")   // raw comp text from posting
  remoteFlag      String    @default("")   // remote | hybrid | onsite | ""
  employmentTypeRaw String  @default("")   // raw employment type from source
  urgencyScore    Int       @default(0)    // 0-100, based on recency + easy-apply + immediate-need signals
  source        String    @default("Manual")
  lastActivity  String    @default("")
  contacts      Contact[]
  engagements   Engagement[]
  todos         Todo[]
  milestones    Milestone[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Contact {
  id            Int           @id @default(autoincrement())
  name          String
  title         String        @default("")
  email         String        @default("")
  phone         String        @default("")
  linkedin      String        @default("")
  persona       String        @default("")
  decisionMaker Boolean       @default(false)
  archived      Boolean       @default(false)
  company       Company?      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId     Int?
  engagements   Engagement[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Engagement {
  id        Int      @id @default(autoincrement())
  type      String   // email | call | meeting | note | stage_change | linkedin | other
  notes     String   @default("")
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId Int
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId Int?
  createdAt DateTime @default(now())
}

model Todo {
  id        Int      @id @default(autoincrement())
  text      String
  completed Boolean  @default(false)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Milestone {
  id        Int      @id @default(autoincrement())
  title     String
  status    String   @default("planned") // planned | in-progress | done
  notes     String   @default("")
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId Int
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScrapeResult {
  id             Int      @id @default(autoincrement())
  url            String
  source         String   // linkedin | crunchbase | website | g2_clutch | job_boards | news_pr
  pipeline       String
  resultData     String   @default("{}") // full JSON of scraped data
  matchedSignals String   @default("[]") // JSON array
  imported       Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model EnrichmentLog {
  id          Int      @id @default(autoincrement())
  contactId   Int?
  contactName String   @default("")
  provider    String   // hunter | rocketreach
  query       String   @default("") // what was searched
  resultData  String   @default("{}") // JSON response
  success     Boolean  @default(false)
  createdAt   DateTime @default(now())
}
